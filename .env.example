# Web版 (Vercel) バックエンド用の環境変数。
# ローカル検証時は同じ内容を .env.local にコピーして値を設定してください (.env.local は git管理外)。
# Vercel 本番/プレビュー環境では `vercel env add` またはダッシュボードの Settings > Environment Variables で設定します。

# Neon (Serverless Postgres) の接続文字列。Neon ダッシュボードの Connection string からコピー。
# 例: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# JWTの署名鍵。ランダムな長い文字列を設定してください (例: openssl rand -base64 32)
JWT_SECRET=
