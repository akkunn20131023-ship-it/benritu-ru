# ============================================================
# Mytnela Flow 環境変数
# ローカル検証時は .env.local にコピーして値を設定してください (.env.local は git 管理外)。
# Vercel / Netlify / Cloudflare Pages ではダッシュボードの環境変数に設定します。
# ============================================================

# --- 公開Web版 (フロントエンド) --------------------------------
# データの保存先モード。
#   local  : ブラウザ内 (localStorage) に保存。サーバー/ログイン不要で誰でも即利用可 (デフォルト・推奨)。
#   remote : 下記の Postgres バックエンドに同期保存 (JWT 匿名セッション)。
VITE_DATA_MODE=local

# 公開する実ドメイン。ビルド時に canonical / OGP / robots.txt / sitemap.xml へ埋め込まれる
# (scripts/gen-seo.mjs と Vite の %VITE_SITE_URL% 置換)。JS実行後は src/lib/seo.ts が実オリジンへ
# さらに追従する。Vercel等ではダッシュボードの環境変数に設定すると .env.production より優先される。
# 未設定時の既定値は .env.production の https://mytnelaflow.app。
# VITE_SITE_URL=https://your-domain.com

# リアルタイム共通基盤 (オンライン機能: チャット/共同メモ/共同ToDo/ゲーム等) の接続先。
# 未設定ならオンライン機能は「オフ」表示になり、他の機能は通常どおり使えます。
# realtime-server/ を任意のホスト(Render/Fly/Railway/VPS等)にデプロイし、その wss URL を設定します。
# ローカル検証: `npm run realtime` で 8787 番に起動 → VITE_REALTIME_URL=ws://localhost:8787
# VITE_REALTIME_URL=wss://realtime.example.com

# --- サーバー同期版 (VITE_DATA_MODE=remote のときのみ必要) ---------
# Neon などの Serverless Postgres 接続文字列。
# 例: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# JWT 署名鍵。ランダムな長い文字列 (例: openssl rand -base64 32)。
JWT_SECRET=
